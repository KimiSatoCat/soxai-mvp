# =============================================================
# SOXAI MVP Proxy — Environment Variables
# =============================================================
# Copy this file to .env and fill in all REQUIRED values.
# The proxy loads .env automatically via dotenv.
# Do NOT commit .env to version control.
# =============================================================

# --- REQUIRED --------------------------------------------------

# SOXAI API base URL.
# Confirmed from documentation: https://soxai-firebase.df.r.appspot.com
# Login is sent to: {SOXAI_API_BASE}/api/login
SOXAI_API_BASE=https://soxai-firebase.df.r.appspot.com

# DailyInfoData endpoint path (relative to SOXAI_API_BASE).
# localId is appended as path parameter: /api/DailyInfoData/{localId}
# Time field in DailyInfoData: local time
ENDPOINT_DAILY_INFO=/api/DailyInfoData

# DailyDetailData endpoint path (relative to SOXAI_API_BASE).
# localId is appended as path parameter: /api/DailyDetailData/{localId}
# Time field in DailyDetailData: UTC
ENDPOINT_DAILY_DETAIL=/api/DailyDetailData

# --- OPTIONAL --------------------------------------------------

# Proxy server port (default: 3001)
# PROXY_PORT=3001

# --- NOT REQUIRED IN CURRENT IMPLEMENTATION --------------------
# FIREBASE_API_KEY is NOT used in the current implementation.
# Login is handled via SOXAI's own /api/login endpoint, which
# internally handles Firebase authentication.
# If a future revision requires direct Firebase access, this
# variable can be re-enabled.
# FIREBASE_API_KEY=
